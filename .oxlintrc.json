{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "rules": {
    "typescript/consistent-type-definitions": ["error", "type"],
    "typescript/no-explicit-any": "error",
    "typescript/no-floating-promises": "error"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  }
}
